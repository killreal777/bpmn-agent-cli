<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_BenchmarkLinear" targetNamespace="http://bpmn-agent-cli/benchmarks">
  <bpmn:process id="Process_BenchmarkLinear" name="Benchmark linear process" isExecutable="true">
    <bpmn:startEvent id="StartEvent_Linear" name="Request received">
      <bpmn:outgoing>Flow_Start_Work</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_DoWork" name="Do work" camunda:delegateExpression="${workDelegate}">
      <bpmn:incoming>Flow_Start_Work</bpmn:incoming>
      <bpmn:outgoing>Flow_Work_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_Linear" name="Completed">
      <bpmn:incoming>Flow_Work_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_Work" sourceRef="StartEvent_Linear" targetRef="Task_DoWork" />
    <bpmn:sequenceFlow id="Flow_Work_End" sourceRef="Task_DoWork" targetRef="EndEvent_Linear" />
  </bpmn:process>
</bpmn:definitions>
