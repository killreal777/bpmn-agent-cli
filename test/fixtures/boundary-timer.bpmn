<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_BoundaryTimer">
  <bpmn:process id="Process_BoundaryTimer" name="Boundary timer">
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_Start_To_Work</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_Start_To_Work" sourceRef="StartEvent_1" targetRef="Activity_Work" />
    <bpmn:serviceTask id="Activity_Work" name="Do work">
      <bpmn:incoming>Flow_Start_To_Work</bpmn:incoming>
      <bpmn:outgoing>Flow_Work_To_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="Boundary_Timer" name="Timeout" attachedToRef="Activity_Work">
      <bpmn:outgoing>Flow_Timer_To_Manual</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT10M</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_Timer_To_Manual" sourceRef="Boundary_Timer" targetRef="Activity_Manual" />
    <bpmn:manualTask id="Activity_Manual" name="Manual review">
      <bpmn:incoming>Flow_Timer_To_Manual</bpmn:incoming>
      <bpmn:outgoing>Flow_Manual_To_End</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:sequenceFlow id="Flow_Work_To_End" sourceRef="Activity_Work" targetRef="EndEvent_1" />
    <bpmn:sequenceFlow id="Flow_Manual_To_End" sourceRef="Activity_Manual" targetRef="EndEvent_1" />
    <bpmn:endEvent id="EndEvent_1">
      <bpmn:incoming>Flow_Work_To_End</bpmn:incoming>
      <bpmn:incoming>Flow_Manual_To_End</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
</bpmn:definitions>
