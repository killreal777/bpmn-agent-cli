<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  id="Definitions_Cycle">
  <bpmn:process id="Process_Cycle" name="Cycle">
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_Start_To_A</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_Start_To_A" sourceRef="StartEvent_1" targetRef="Task_A" />
    <bpmn:task id="Task_A" name="A">
      <bpmn:incoming>Flow_Start_To_A</bpmn:incoming>
      <bpmn:incoming>Flow_B_To_A</bpmn:incoming>
      <bpmn:outgoing>Flow_A_To_B</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_A_To_B" sourceRef="Task_A" targetRef="Task_B" />
    <bpmn:task id="Task_B" name="B">
      <bpmn:incoming>Flow_A_To_B</bpmn:incoming>
      <bpmn:outgoing>Flow_B_To_A</bpmn:outgoing>
      <bpmn:outgoing>Flow_B_To_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_B_To_A" sourceRef="Task_B" targetRef="Task_A" />
    <bpmn:sequenceFlow id="Flow_B_To_End" sourceRef="Task_B" targetRef="EndEvent_1" />
    <bpmn:endEvent id="EndEvent_1">
      <bpmn:incoming>Flow_B_To_End</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
</bpmn:definitions>
