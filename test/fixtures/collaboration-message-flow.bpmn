<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  id="Definitions_CollaborationMessageFlow">
  <bpmn:collaboration id="Collaboration_1" name="Message collaboration">
    <bpmn:participant id="Participant_A" name="Sender" processRef="Process_A" />
    <bpmn:participant id="Participant_B" name="Receiver" processRef="Process_B" />
    <bpmn:messageFlow id="MessageFlow_1" name="Request" sourceRef="Task_Send" targetRef="Task_Receive" />
  </bpmn:collaboration>
  <bpmn:process id="Process_A" name="Sender process">
    <bpmn:task id="Task_Send" name="Send request" />
  </bpmn:process>
  <bpmn:process id="Process_B" name="Receiver process">
    <bpmn:task id="Task_Receive" name="Receive request" />
  </bpmn:process>
</bpmn:definitions>
